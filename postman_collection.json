{
  "info": {
    "name": "apivaja",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tina.kovac@example.com\",\n  \"password\": \"ZelenaSoba123!\",\n  \"name\": \"Tina Kovač\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.token) {",
                  "  pm.environment.set('token', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tina.kovac@example.com\",\n  \"password\": \"ZelenaSoba123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Matches",
      "item": [
        {
          "name": "List All",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/matches",
              "host": ["{{baseUrl}}"],
              "path": ["api", "matches"]
            }
          }
        },
        {
          "name": "List Mine",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/matches?mine=true",
              "host": ["{{baseUrl}}"],
              "path": ["api", "matches"],
              "query": [
                {
                  "key": "mine",
                  "value": "true"
                }
              ]
            }
          }
        },
        {
          "name": "Create",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const id = json && json.data && json.data.id;",
                  "if (id) {",
                  "  pm.environment.set('matchId', String(id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"homeTeam\": \"Maribor\",\n  \"awayTeam\": \"Olimpija\",\n  \"matchDate\": \"2026-05-01T18:00:00.000Z\",\n  \"location\": \"Ljudski vrt\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/matches",
              "host": ["{{baseUrl}}"],
              "path": ["api", "matches"]
            }
          }
        },
        {
          "name": "Get By Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/matches/{{matchId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "matches", "{{matchId}}"]
            }
          }
        },
        {
          "name": "Update (PUT)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"homeTeam\": \"Celje\",\n  \"awayTeam\": \"Koper\",\n  \"matchDate\": \"2026-05-15T19:30:00.000Z\",\n  \"location\": \"Stadion Z\'dežele\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/matches/{{matchId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "matches", "{{matchId}}"]
            }
          }
        },
        {
          "name": "Update (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"location\": \"Stožice\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/matches/{{matchId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "matches", "{{matchId}}"]
            }
          }
        },
        {
          "name": "Delete",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/matches/{{matchId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "matches", "{{matchId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Football",
      "item": [
        {
          "name": "Fixtures",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/football?start=2026-05-01",
              "host": ["{{baseUrl}}"],
              "path": ["api", "football"],
              "query": [
                {
                  "key": "start",
                  "value": "2026-05-01"
                }
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "matchId",
      "value": "1"
    }
  ]
}
